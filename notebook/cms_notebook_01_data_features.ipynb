   "source": [
    "# Notebook 01: Data and Features\n",
    "## Project: Medicare Provider Billing Anomalies in No-Fault PIP States\n",
    "\n",
    "**Central question:** Which providers in no-fault states are billing  \n",
    "at statistically implausible rates compared to their specialty peers?\n",
    "\n",
    "**This notebook:**\n",
    "1. Loads the CMS Medicare Part B raw file using DuckDB SQL\n",
    "2. Filters to no-fault PIP states and soft-tissue injury specialties\n",
    "3. Engineers three core features for anomaly detection\n",
    "4. Saves clean feature data to parquet\n",
    "\n",
    "**Input:** `data/raw/MUP_PHY_R25_P05_V20_D23_Prov_Svc.csv` (~3.5 GB)\n",
    "\n",
    "**Output:** `data/processed/cms_features.parquet`\n",
    "\n",
    "---"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 0. Setup"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import subprocess, sys\n",
    "for pkg in ['duckdb', 'pyarrow', 'pandas', 'numpy', 'matplotlib', 'seaborn']:\n",
    "    subprocess.check_call([sys.executable, '-m', 'pip', 'install', pkg, '-q'])\n",
    "print('All packages ready.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.ticker as mticker\n",
    "import duckdb\n",
    "import os\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "os.makedirs('data/raw',       exist_ok=True)\n",
    "os.makedirs('data/processed', exist_ok=True)\n",
    "os.makedirs('outputs/figures', exist_ok=True)\n",
    "\n",
    "plt.rcParams.update({\n",
    "    'figure.dpi': 150, 'savefig.dpi': 300,\n",
    "    'savefig.bbox': 'tight', 'font.size': 11,\n",
    "    'axes.titlesize': 13, 'axes.titleweight': 'bold',\n",
    "    'axes.spines.top': False, 'axes.spines.right': False,\n",
    "    'figure.facecolor': 'white', 'axes.facecolor': 'white'\n",
    "})\n",
    "\n",
    "FRAUD_COLOR = '#D85A30'\n",
    "LEGIT_COLOR = '#378ADD'\n",
    "NEUT_COLOR  = '#888780'\n",
    "WARN_COLOR  = '#EF9F27'\n",
    "\n",
    "# --- File paths ---\n",
    "# Update CMS_RAW if your filename differs\n",
    "CMS_RAW = 'data/raw/MUP_PHY_R25_P05_V20_D23_Prov_Svc.csv'\n",
    "CMS_OUT = 'data/processed/cms_features.parquet'\n",
    "\n",
    "print(f'CMS raw file: {\"FOUND\" if os.path.exists(CMS_RAW) else \"MISSING\"}')\n",
    "if os.path.exists(CMS_RAW):\n",
    "    print(f'File size: {os.path.getsize(CMS_RAW)/1e9:.1f} GB')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 1. DuckDB SQL filter\n",
    "\n",
    "DuckDB runs standard SQL directly on the CSV file.  \n",
    "The 3.5 GB file never loads into memory, only the filtered rows do.  \n",
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- Filter definitions ---\n",
    "\n",
    "# No-fault states with meaningful PIP fraud history\n",
    "# These are the only US states with mandatory no-fault PIP laws\n",
    "# and sufficient provider populations for reliable peer comparison\n",
    "PIP_STATES = ['NY', 'NJ', 'MI', 'FL', 'MA', 'HI', 'PA']\n",
    "\n",
    "# Soft-tissue injury specialties — where PIP mill billing occurs\n",
    "PIP_SPECIALTIES = [\n",
    "    'Physical Medicine and Rehabilitation',\n",
    "    'Chiropractic',\n",
    "    'Neurology',\n",
    "    'Orthopedic Surgery',\n",
    "    'Internal Medicine',\n",
    "    'Pain Management',\n",
    "    'Interventional Pain Management'\n",
    "]\n",
    "\n",
    "# Procedure codes relevant to soft-tissue injury treatment\n",
    "# These are the codes that appear most frequently in PIP claim files\n",
    "PIP_HCPCS = [\n",
    "    '99212', '99213', '99214', '99215',   # office visits — upcoding target\n",
    "    '97010', '97012', '97014', '97018',   # physical therapy modalities\n",
    "    '97110', '97112', '97140', '97530',   # therapeutic procedures\n",
    "    '98940', '98941', '98942',            # chiropractic manipulation\n",
    "    '64483', '64484', '62322', '62323',   # pain injections\n",
    "    '72141', '72148', '73221', '73223'    # MRI imaging\n",
    "]\n",
    "\n",
    "# Format for SQL IN clauses\n",
    "states_sql      = ', '.join([f\"'{s}'\" for s in PIP_STATES])\n",
    "specialties_sql = ', '.join([f\"'{s}'\" for s in PIP_SPECIALTIES])\n",
    "hcpcs_sql       = ', '.join([f\"'{h}'\" for h in PIP_HCPCS])\n",
    "\n",
    "print(f'Filtering to:')\n",
    "print(f'  {len(PIP_STATES)} no-fault states: {PIP_STATES}')\n",
    "print(f'  {len(PIP_SPECIALTIES)} specialties')\n",
    "print(f'  {len(PIP_HCPCS)} procedure codes')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Peek at actual column names before running the full query\n",
    "# CMS occasionally changes column names between release years\n",
    "con = duckdb.connect()\n",
    "\n",
    "sample = con.execute(\n",
    "    f\"SELECT * FROM read_csv_auto('{CMS_RAW}') LIMIT 2\"\n",
    ").df()\n",
    "\n",
    "print('CMS column names:')\n",
    "for col in sample.columns:\n",
    "    print(f'  {col}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Run the DuckDB SQL filter query\n",
    "# Standard SQL: SELECT the columns we need, WHERE filters rows\n",
    "# Tot_Benes >= 11 because CMS suppresses records with <= 10 patients\n",
    "\n",
    "print('Running DuckDB SQL query on CMS file...')\n",
    "print('Expected time: 30-90 seconds\\n')\n",
    "\n",
    "query = f\"\"\"\n",
    "    SELECT\n",
    "        Rndrng_NPI,\n",
    "        Rndrng_Prvdr_Last_Org_Name,\n",
    "        Rndrng_Prvdr_Type,\n",
    "        Rndrng_Prvdr_State_Abrvtn,\n",
    "        Rndrng_Prvdr_Ent_Cd,\n",
    "        HCPCS_Cd,\n",
    "        HCPCS_Desc,\n",
    "        Place_Of_Srvc,\n",
    "        Tot_Srvcs,\n",
    "        Tot_Benes,\n",
    "        Avg_Sbmtd_Chrg,\n",
    "        Avg_Mdcr_Alowd_Amt,\n",
    "        Avg_Mdcr_Pymt_Amt\n",
    "    FROM read_csv_auto('{CMS_RAW}')\n",
    "    WHERE Rndrng_Prvdr_State_Abrvtn IN ({states_sql})\n",
    "    AND   Rndrng_Prvdr_Type          IN ({specialties_sql})\n",
    "    AND   HCPCS_Cd                   IN ({hcpcs_sql})\n",
    "    AND   Tot_Benes                  >= 11\n",
    "\"\"\"\n",
    "\n",
    "cms = con.execute(query).df()\n",
    "con.close()\n",
    "\n",
    "# Reset any category dtypes — prevents groupby memory issues\n",
    "for col in cms.select_dtypes(include='category').columns:\n",
    "    cms[col] = cms[col].astype('str')\n",
    "\n",
    "print(f'Query complete.')\n",
    "print(f'Rows returned:    {len(cms):,}')\n",
    "print(f'Memory usage:     {cms.memory_usage(deep=True).sum()/1e6:.1f} MB')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 2. Data validation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print('=== Data validation ===')\n",
    "print(f'Shape: {cms.shape}')\n",
    "print(f'Unique providers: {cms[\"Rndrng_NPI\"].nunique():,}')\n",
    "\n",
    "print(f'\\nRows by state:')\n",
    "print(cms['Rndrng_Prvdr_State_Abrvtn'].value_counts().to_string())\n",
    "\n",
    "print(f'\\nRows by specialty:')\n",
    "print(cms['Rndrng_Prvdr_Type'].value_counts().to_string())\n",
    "\n",
    "print(f'\\nEntity types (I=individual, O=organization):')\n",
    "print(cms['Rndrng_Prvdr_Ent_Cd'].value_counts().to_string())\n",
    "\n",
    "print(f'\\nNull counts:')\n",
    "nulls = cms.isnull().sum()\n",
    "null_cols = nulls[nulls > 0]\n",
    "print(null_cols.to_string() if len(null_cols) > 0 else 'No nulls found.')\n",
    "\n",
    "# Flag Hawaii — thin peer groups\n",
    "cms['low_confidence'] = (\n",
    "    cms['Rndrng_Prvdr_State_Abrvtn'] == 'HI'\n",
    ").astype(bool)\n",
    "print(f'\\nHawaii rows flagged as low confidence: {cms[\"low_confidence\"].sum():,}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 3. Feature engineering\n",
    "\n",
    "Three features only. Each one captures a different dimension of billing anomaly.\n",
    "\n",
    "**Feature 1: Billing inflation ratio (charge-to-payment ratio)**  \n",
    "What the provider submits divided by what Medicare pays.  \n",
    "Medicare payment is fixed per code, only the submitted charge varies.  \n",
    "Legitimate range: 1.5x to 3x. Anomalous: above 8x.\n",
    "\n",
    "**Feature 2: Services per patient**  \n",
    "Total services billed divided by distinct patient count.  \n",
    "Captures medically implausible treatment frequency.  \n",
    "Legitimate range for soft tissue: 8–14 sessions. Anomalous: above 30.\n",
    "\n",
    "**Feature 3: Peer group z-score**  \n",
    "How many standard deviations above the peer mean is this provider?  \n",
    "Peer group = same specialty + same state + same procedure code.  \n",
    "A z-score above 3.0 means the provider is in the top 0.1% of their peers."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- Feature 1: Billing inflation ratio ---\n",
    "cms['billing_inflation_ratio'] = (\n",
    "    cms['Avg_Sbmtd_Chrg'] /\n",
    "    cms['Avg_Mdcr_Pymt_Amt'].replace(0, np.nan)\n",
    ").replace([np.inf, -np.inf], np.nan)\n",
    "\n",
    "print('Feature 1: billing_inflation_ratio')\n",
    "print(f'  Median: {cms[\"billing_inflation_ratio\"].median():.2f}x')\n",
    "print(f'  Mean:   {cms[\"billing_inflation_ratio\"].mean():.2f}x')\n",
    "print(f'  Above 10x: {(cms[\"billing_inflation_ratio\"] > 10).sum():,} providers')\n",
    "print(f'  Above 20x: {(cms[\"billing_inflation_ratio\"] > 20).sum():,} providers')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- Feature 2: Services per patient ---\n",
    "cms['services_per_patient'] = (\n",
    "    cms['Tot_Srvcs'] /\n",
    "    cms['Tot_Benes'].replace(0, np.nan)\n",
    ")\n",
    "\n",
    "print('Feature 2: services_per_patient')\n",
    "print(f'  Median: {cms[\"services_per_patient\"].median():.1f}')\n",
    "print(f'  Mean:   {cms[\"services_per_patient\"].mean():.1f}')\n",
    "print(f'  Above 30: {(cms[\"services_per_patient\"] > 30).sum():,} rows')\n",
    "print(f'  Above 50: {(cms[\"services_per_patient\"] > 50).sum():,} rows')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- Feature 3: Peer group z-scores ---\n",
    "# Compare each provider only to identical peers:\n",
    "# same specialty + same state + same procedure code + same place of service\n",
    "#\n",
    "# A physical medicine provider in NY billing code 97110 in an office\n",
    "# is compared ONLY to other physical medicine providers\n",
    "# in NY billing 97110 in an office.\n",
    "# This controls for legitimate variation between specialties and geographies.\n",
    "\n",
    "PEER_GROUP = [\n",
    "    'Rndrng_Prvdr_Type',\n",
    "    'Rndrng_Prvdr_State_Abrvtn',\n",
    "    'HCPCS_Cd',\n",
    "    'Place_Of_Srvc'\n",
    "]\n",
    "\n",
    "def peer_zscore(df, group_cols, value_col, new_col):\n",
    "    \"\"\"\n",
    "    Z-score within peer group.\n",
    "    Groups with fewer than 5 members get NaN, too few peers\n",
    "    to produce a meaningful comparison.\n",
    "    \"\"\"\n",
    "    def zscore_safe(x):\n",
    "        if len(x) < 5:\n",
    "            return pd.Series([np.nan] * len(x), index=x.index)\n",
    "        std = x.std()\n",
    "        if std == 0:\n",
    "            return pd.Series([0.0] * len(x), index=x.index)\n",
    "        return (x - x.mean()) / std\n",
    "\n",
    "    df[new_col] = df.groupby(\n",
    "        group_cols, observed=True\n",
    "    )[value_col].transform(zscore_safe)\n",
    "    return df\n",
    "\n",
    "print('Computing peer group z-scores')\n",
    "print('(Comparing each provider to specialty peers)\\n')\n",
    "\n",
    "cms = peer_zscore(\n",
    "    cms, PEER_GROUP,\n",
    "    'billing_inflation_ratio',\n",
    "    'inflation_zscore'\n",
    ")\n",
    "print('  inflation_zscore: done')\n",
    "\n",
    "cms = peer_zscore(\n",
    "    cms, PEER_GROUP,\n",
    "    'services_per_patient',\n",
    "    'svc_per_patient_zscore'\n",
    ")\n",
    "print('  svc_per_patient_zscore: done')\n",
    "\n",
    "print(f'\\nZ-score summary:')\n",
    "for col in ['inflation_zscore', 'svc_per_patient_zscore']:\n",
    "    valid = cms[col].notna().sum()\n",
    "    p95   = cms[col].quantile(0.95)\n",
    "    p99   = cms[col].quantile(0.99)\n",
    "    above3 = (cms[col] > 3.0).sum()\n",
    "    print(f'  {col}:')\n",
    "    print(f'    Valid rows: {valid:,} | p95: {p95:.2f} | p99: {p99:.2f} | above 3.0: {above3:,}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 4. Aggregate to provider level\n",
    "\n",
  
    "We take the **maximum** z-score across all procedure codes per provider.  \n",
    "Maximum captures the worst-case anomaly across everything they bill.  \n",
    "A provider who bills one code extremely anomalously is flagged even if  \n",
    "their other codes look normal."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "provider_features = cms.groupby(\n",
    "    ['Rndrng_NPI', 'Rndrng_Prvdr_Last_Org_Name',\n",
    "     'Rndrng_Prvdr_Type', 'Rndrng_Prvdr_State_Abrvtn',\n",
    "     'Rndrng_Prvdr_Ent_Cd', 'low_confidence'],\n",
    "    observed=True\n",
    ").agg(\n",
    "    total_services          = ('Tot_Srvcs',              'sum'),\n",
    "    total_patients          = ('Tot_Benes',              'sum'),\n",
    "    n_procedure_codes       = ('HCPCS_Cd',               'nunique'),\n",
    "    median_inflation_ratio  = ('billing_inflation_ratio', 'median'),\n",
    "    max_inflation_ratio     = ('billing_inflation_ratio', 'max'),\n",
    "    median_svc_per_patient  = ('services_per_patient',   'median'),\n",
    "    max_inflation_zscore    = ('inflation_zscore',        'max'),\n",
    "    max_svc_zscore          = ('svc_per_patient_zscore',  'max')\n",
    ").reset_index()\n",
    "\n",
    "# Overall services per patient at provider level\n",
    "provider_features['overall_svc_per_patient'] = (\n",
    "    provider_features['total_services'] /\n",
    "    provider_features['total_patients'].replace(0, np.nan)\n",
    ")\n",
    "\n",
    "# Organization flag: 1=clinic or LLC, 0=individual physician\n",
    "provider_features['is_organization'] = (\n",
    "    provider_features['Rndrng_Prvdr_Ent_Cd'] == 'O'\n",
    ").astype(int)\n",
    "\n",
    "# Fill NaN z-scores with 0\n",
    "# NaN means peer group had < 5 members, treated as average\n",
    "provider_features[['max_inflation_zscore', 'max_svc_zscore']] = (\n",
    "    provider_features[['max_inflation_zscore', 'max_svc_zscore']].fillna(0)\n",
    ")\n",
    "\n",
    "print(f'Provider feature matrix: {provider_features.shape}')\n",
    "print(f'One row per provider: {provider_features[\"Rndrng_NPI\"].nunique():,}')\n",
    "print(f'\\nQuick stats:')\n",
    "print(f'  Median billing inflation ratio:  {provider_features[\"median_inflation_ratio\"].median():.2f}x')\n",
    "print(f'  Providers with ratio > 10x:      {(provider_features[\"median_inflation_ratio\"] > 10).sum():,}')\n",
    "print(f'  Median services per patient:     {provider_features[\"median_svc_per_patient\"].median():.1f}')\n",
    "print(f'  Organizations vs individuals:    {provider_features[\"is_organization\"].sum():,} orgs | '\n",
    "      f'{(provider_features[\"is_organization\"]==0).sum():,} individuals')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 5. Billing inflation ratio chart"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Distribution of billing inflation ratio by specialty\n",
    "# Cap at 25x for readability. Extreme outliers exist but distort the chart\n",
    "\n",
    "cms_plot = cms[\n",
    "    cms['billing_inflation_ratio'].between(0, 25)\n",
    "].copy()\n",
    "\n",
    "spec_colors = {\n",
    "    'Physical Medicine and Rehabilitation': FRAUD_COLOR,\n",
    "    'Chiropractic':                          WARN_COLOR,\n",
    "    'Pain Management':                       '#D4537E',\n",
    "    'Interventional Pain Management':        '#993556',\n",
    "    'Neurology':                             LEGIT_COLOR,\n",
    "    'Orthopedic Surgery':                    '#1D9E75',\n",
    "    'Internal Medicine':                     NEUT_COLOR,\n",
    "}\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(12, 5))\n",
    "\n",
    "for spec in cms_plot['Rndrng_Prvdr_Type'].unique():\n",
    "    data  = cms_plot[\n",
    "        cms_plot['Rndrng_Prvdr_Type'] == spec\n",
    "    ]['billing_inflation_ratio'].dropna()\n",
    "    color = spec_colors.get(spec, NEUT_COLOR)\n",
    "    ax.hist(\n",
    "        data, bins=50, alpha=0.45,\n",
    "        density=True, label=spec, color=color\n",
    "    )\n",
    "\n",
    "ax.axvline(\n",
    "    x=3, color='green', linestyle=':',\n",
    "    linewidth=1.5, label='Legitimate upper bound (~3x)'\n",
    ")\n",
    "ax.axvline(\n",
    "    x=8, color=FRAUD_COLOR, linestyle='--',\n",
    "    linewidth=1.5, label='Anomaly threshold (8x)'\n",
    ")\n",
    "\n",
    "ax.set_title(\n",
    "    'Billing inflation ratio by specialty\\n'\n",
    "    'Providers to the right of the red line submit charges 8x+ above Medicare payment',\n",
    "    fontweight='bold'\n",
    ")\n",
    "ax.set_xlabel('Billing inflation ratio (submitted charge ÷ Medicare payment)')\n",
    "ax.set_ylabel('Density')\n",
    "ax.legend(fontsize=8, loc='upper right')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('outputs/figures/01_billing_inflation_by_specialty.png')\n",
    "plt.show()\n",
    "print('Saved: outputs/figures/01_billing_inflation_by_specialty.png')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
