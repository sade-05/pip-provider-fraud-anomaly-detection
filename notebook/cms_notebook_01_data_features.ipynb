    "---\n",
    "## Notebook 01 Summary"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print('=' * 55)\n",
    "print('NOTEBOOK 01 COMPLETE')\n",
    "print('=' * 55)\n",
    "print(f'\\nData loaded via DuckDB SQL from {os.path.getsize(CMS_RAW)/1e9:.1f} GB raw file')\n",
    "print(f'Rows after SQL filter:   {len(cms):,}')\n",
    "print(f'Unique providers:        {provider_features[\"Rndrng_NPI\"].nunique():,}')\n",
    "print(f'\\nFeatures engineered:')\n",
    "print(f'  billing_inflation_ratio   — submitted charge / Medicare payment')\n",
    "print(f'  services_per_patient      — total services / distinct patients')\n",
